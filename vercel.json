{
  "rewrites": [
    {
      "source": "/api/rest/v1/:path*",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/rest/v1/:path*"
    },
    {
      "source": "/api/auth/v1/:path*",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/auth/v1/:path*"
    },
    {
      "source": "/api/storage/v1/:path*",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/storage/v1/:path*"
    },
    {
      "source": "/api/functions/v1/:path*",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/:path*"
    },

    { "source": "/events/today", "destination": "/index.html" },
    { "source": "/events/this-week", "destination": "/index.html" },
    { "source": "/events/this-weekend", "destination": "/index.html" },
    { "source": "/events/free", "destination": "/index.html" },
    { "source": "/events/workshops", "destination": "/index.html" },

    {
      "source": "/events/:category/:locality",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/events-list-ssr?category=:category&locality=:locality"
    },
    {
      "source": "/events/:slug",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/event-ssr?slug=:slug"
    },
    {
      "source": "/events",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/events-list-ssr"
    },

    {
      "source": "/artists/:slug",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/artist-ssr?slug=:slug"
    },

    {
      "source": "/jaipur/:slug",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/locality-ssr?slug=:slug"
    },

    {
      "source": "/stories/:slug",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/story-ssr?slug=:slug"
    },
    {
      "source": "/stories",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/stories-index-ssr"
    },

    {
      "source": "/sitemap.xml",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/sitemap-index"
    },
    {
      "source": "/sitemap-events.xml",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/sitemap-events-xml"
    },
    {
      "source": "/sitemap-stories.xml",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/sitemap-stories"
    },
    {
      "source": "/sitemap-news.xml",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/sitemap?type=news"
    },
    {
      "source": "/sitemap-news-google.xml",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/sitemap?type=news-sitemap"
    },
    {
      "source": "/sitemap-artists.xml",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/sitemap-artists"
    },

    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "redirects": [
    { "source": "/localities/:slug", "destination": "/jaipur/:slug", "permanent": true },
    { "source": "/localities", "destination": "/jaipur", "permanent": true }
  ]
}
