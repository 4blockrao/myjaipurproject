{
  "routes": [
    {
      "src": "^/localities/?$",
      "status": 308,
      "headers": { "Location": "/jaipur" }
    },
    {
      "src": "^/localities/(?<slug>[^/]+)/?$",
      "status": 308,
      "headers": { "Location": "/jaipur/$slug" }
    },

    {
      "src": "^/events/?$",
      "dest": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/events-list-ssr"
    },
    {
      "src": "^/events/(?<category>[^/]+)/(?<locality>[^/]+)/?$",
      "dest": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/events-list-ssr?category=$category&locality=$locality"
    },
    {
      "src": "^/events/(?<slug>[^/]+)/?$",
      "dest": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/event-ssr?slug=$slug"
    },

    {
      "src": "^/artists/(?<slug>[^/]+)/?$",
      "dest": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/artist-ssr?slug=$slug"
    },

    {
      "src": "^/jaipur/(?<slug>[^/]+)/?$",
      "dest": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/page-ssr?type=locality&slug=$slug"
    },

    {
      "src": "^/sitemap\\.xml$",
      "dest": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/sitemap-index"
    },
    {
      "src": "^/sitemap-events\\.xml$",
      "dest": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/sitemap-events-xml"
    },
    {
      "src": "^/sitemap-news\\.xml$",
      "dest": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/sitemap?type=news"
    },
    {
      "src": "^/sitemap-news-google\\.xml$",
      "dest": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/sitemap?type=news-sitemap"
    },
    {
      "src": "^/sitemap-artists\\.xml$",
      "dest": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/sitemap-artists"
    },

    {
      "src": "^(.*)$",
      "dest": "/index.html"
    }
  ]
}
