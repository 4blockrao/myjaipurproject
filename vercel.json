{
  "routes": [
    { "handle": "filesystem" },

    /* ---------- EVENTS SSR ---------- */
    {
      "src": "^/events/([^/]+)/([^/]+)/?$",
      "dest": "https://api.jaipurcircle.com/functions/v1/events-list-ssr?category=$1&locality=$2"
    },
    {
      "src": "^/events/([^/]+)/?$",
      "dest": "https://api.jaipurcircle.com/functions/v1/event-ssr?slug=$1"
    },
    {
      "src": "^/events/?$",
      "dest": "https://api.jaipurcircle.com/functions/v1/events-list-ssr"
    },

    /* ---------- ARTISTS SSR ---------- */
    {
      "src": "^/artists/([^/]+)/?$",
      "dest": "https://api.jaipurcircle.com/functions/v1/artist-ssr?slug=$1"
    },

    /* ---------- LOCALITY SSR ---------- */
    {
      "src": "^/jaipur/([^/]+)/?$",
      "dest": "https://api.jaipurcircle.com/functions/v1/locality-ssr?slug=$1"
    },

    /* ---------- LEGACY LOCALITIES REDIRECT ---------- */
    {
      "src": "^/localities/([^/]+)/?$",
      "dest": "https://api.jaipurcircle.com/functions/v1/locality-redirect?slug=$1"
    },
    {
      "src": "^/localities/?$",
      "dest": "https://api.jaipurcircle.com/functions/v1/locality-redirect"
    },

    /* ---------- STORIES SSR ---------- */
    {
      "src": "^/stories/([^/]+)/?$",
      "dest": "https://api.jaipurcircle.com/functions/v1/story-ssr?slug=$1"
    },
    {
      "src": "^/stories/?$",
      "dest": "https://api.jaipurcircle.com/functions/v1/stories-index-ssr"
    },

    /* ---------- SITEMAPS ---------- */
    {
      "src": "^/sitemap\\.xml$",
      "dest": "https://api.jaipurcircle.com/functions/v1/sitemap-index"
    },
    {
      "src": "^/sitemap-events\\.xml$",
      "dest": "https://api.jaipurcircle.com/functions/v1/sitemap-events-xml"
    },
    {
      "src": "^/sitemap-stories\\.xml$",
      "dest": "https://api.jaipurcircle.com/functions/v1/sitemap-stories"
    },
    {
      "src": "^/sitemap-news\\.xml$",
      "dest": "https://api.jaipurcircle.com/functions/v1/sitemap?type=news"
    },
    {
      "src": "^/sitemap-news-google\\.xml$",
      "dest": "https://api.jaipurcircle.com/functions/v1/sitemap?type=news-sitemap"
    },
    {
      "src": "^/sitemap-artists\\.xml$",
      "dest": "https://api.jaipurcircle.com/functions/v1/sitemap-artists"
    },

    /* ---------- SPA FALLBACK (ALWAYS LAST) ---------- */
    { "src": "^/(.*)$", "dest": "/index.html" }
  ]
}
