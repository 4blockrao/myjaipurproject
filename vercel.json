{
  "routes": [
    {
      "src": "^/api/rest/v1/(.*)$",
      "dest": "https://rbenryjgtbrjvqvxbigq.supabase.co/rest/v1/$1"
    },
    {
      "src": "^/api/auth/v1/(.*)$",
      "dest": "https://rbenryjgtbrjvqvxbigq.supabase.co/auth/v1/$1"
    },
    {
      "src": "^/api/storage/v1/(.*)$",
      "dest": "https://rbenryjgtbrjvqvxbigq.supabase.co/storage/v1/$1"
    },
    {
      "src": "^/api/functions/v1/(.*)$",
      "dest": "https://rbenryjgtbrjvqvxbigq.supabase.co/functions/v1/$1"
    },
    {
      "src": "^/events/category/([^/]+)/?$",
      "dest": "/api/events-list-ssr?path=/events/category/$1"
    },
    {
      "src": "^/events/today/?$",
      "dest": "/api/events-list-ssr?path=/events/today"
    },
    {
      "src": "^/events/tomorrow/?$",
      "dest": "/api/events-list-ssr?path=/events/tomorrow"
    },
    {
      "src": "^/events/this-weekend/?$",
      "dest": "/api/events-list-ssr?path=/events/this-weekend"
    },
    {
      "src": "^/events/this-week/?$",
      "dest": "/api/events-list-ssr?path=/events/this-week"
    },
    {
      "src": "^/events/next-month/?$",
      "dest": "/api/events-list-ssr?path=/events/next-month"
    },
    {
      "src": "^/events/near-me/?$",
      "dest": "/api/events-list-ssr?path=/events/near-me"
    },
    {
      "src": "^/events/?$",
      "dest": "/api/events-list-ssr?path=/events"
    },
    {
      "src": "^/events/([^/]+)/?$",
      "dest": "/api/event-proxy?slug=$1"
    },
    {
