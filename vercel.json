      "destination": "/index.html"
    },
    {
      "source": "/events/free",
      "destination": "/index.html"
    },
    {
      "source": "/events/workshops",
      "destination": "/index.html"
    },

    {
      "source": "/events/:slug",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/event-ssr?slug=:slug"
    },

    {
      "source": "/sitemap.xml",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/sitemap?type=index"
    },
    {
      "source": "/sitemap-pages.xml",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/sitemap?type=pages"
    },
    {
      "source": "/sitemap-localities.xml",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/sitemap?type=localities"
    },
    {
      "source": "/sitemap-zones.xml",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/sitemap?type=zones"
    },
    {
      "source": "/sitemap-deals.xml",
