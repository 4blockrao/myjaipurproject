      "dest": "/api/jaipur-proxy?slug=$1"
    },
    {
      "src": "^/artists/([^/]+)/?$",
      "dest": "/api/artist-proxy?slug=$1"
    },
    {
      "src": "^/venues/([^/]+)/?$",
      "dest": "/api/venue-proxy?slug=$1"
    },
    {
      "src": "/sitemap.xml",
      "dest": "https://rbenryjgtbrjvqvxbigq.supabase.co/functions/v1/sitemap"
    },
    {
      "src": "/sitemap-index.xml",
      "dest": "https://rbenryjgtbrjvqvxbigq.supabase.co/functions/v1/sitemap"
    },
    {
      "src": "^/sitemaps/([^/]+)\\.xml$",
      "dest": "https://rbenryjgtbrjvqvxbigq.supabase.co/functions/v1/sitemap/sitemaps/$1.xml"
    },
    {
      "src": "^/sitemap-events\\.xml$",
      "dest": "https://rbenryjgtbrjvqvxbigq.supabase.co/functions/v1/sitemap/sitemaps/events.xml"
    },
    {
      "src": "^/sitemap-stories\\.xml$",
      "dest": "https://rbenryjgtbrjvqvxbigq.supabase.co/functions/v1/sitemap-stories"
