// supabase/functions/sitemap/index.ts
Deno.serve(async (req) => {
  const url = new URL(req.url);
  const type = url.searchParams.get('type');
  
  let sitemapXML = '';
  
  switch(type) {
    case 'events':
      sitemapXML = await generateEventsSitemap();
      break;
    case 'categories':
      sitemapXML = await generateCategoriesSitemap();
      break;
    case 'deals':
      sitemapXML = await generateDealsSitemap();
      break;
    case 'localities':
      sitemapXML = await generateLocalitiesSitemap();
      break;
    case 'merchants':
      sitemapXML = await generateMerchantsSitemap();
      break;
    case 'news':
      sitemapXML = await generateNewsSitemap();
      break;
    case 'static':
      sitemapXML = await generateStaticSitemap();
      break;
    default:
      sitemapXML = await generateMainSitemap(); // Your existing logic
  }
  
  return new Response(sitemapXML, {
    headers: {
      'Content-Type': 'application/xml',
      'Cache-Control': 'public, max-age=3600'
    }
  });
});
