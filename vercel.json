{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/merchant/:id",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/merchant-redirect?id=:id"
    },

    // ---------------------------
    // EVENTS: SEO SSR LISTINGS
    // ---------------------------

    // Events hub (indexable)
    {
      "source": "/events",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/events-list-ssr"
    },

    // Filter pages (SSR listings so they get correct meta/schema; avoids SPA thin-index bloat)
    {
      "source": "/events/today",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/events-list-ssr?filter=today"
    },
    {
      "source": "/events/this-week",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/events-list-ssr?filter=this-week"
    },
    {
      "source": "/events/this-weekend",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/events-list-ssr?filter=this-weekend"
    },
    {
      "source": "/events/free",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/events-list-ssr?filter=free"
    },
    {
      "source": "/events/workshops",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/events-list-ssr?filter=workshops"
    },

    // Category + locality listings (indexability gated by inventory threshold inside SSR)
    {
      "source": "/events/:category/:locality",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/events-list-ssr?category=:category&locality=:locality"
    },

    // IMPORTANT: Event detail SSR must come AFTER the above,
    // so it doesn't hijack /events/create or /events/today etc.
    {
      "source": "/events/:slug",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/event-ssr?slug=:slug"
    },

    // ---------------------------
    // SITEMAPS (first-party URLs)
    // ---------------------------

    {
      "source": "/sitemap.xml",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/sitemap?type=index"
    },
    {
      "source": "/sitemap-pages.xml",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/sitemap?type=pages"
    },
    {
      "source": "/sitemap-localities.xml",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/sitemap?type=localities"
    },
    {
      "source": "/sitemap-zones.xml",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/sitemap?type=zones"
    },
    {
      "source": "/sitemap-deals.xml",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/sitemap?type=deals"
    },
    {
      "source": "/sitemap-merchants.xml",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/sitemap?type=merchants"
    },
    {
      "source": "/sitemap-events.xml",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/sitemap?type=events"
    },
    {
      "source": "/sitemap-news.xml",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/sitemap?type=news"
    },
    {
      "source": "/sitemap-news-google.xml",
      "destination": "https://buwhgxyutfwadazjswio.supabase.co/functions/v1/sitemap?type=news-sitemap"
    },

    // ---------------------------
    // SPA fallback
    // ---------------------------
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
