{
  "routes": [
    {
      "src": "^/api/(.*)$",
      "dest": "https://buwhgxyutfwadazjswio.supabase.co/$1"
    },

    { "handle": "filesystem" },

    {
      "src": "^/events/([^/]+)/([^/]+)/?$",
      "dest": "/api/functions/v1/events-list-ssr?category=$1&locality=$2"
    },
    {
      "src": "^/events/([^/]+)/?$",
      "dest": "/api/functions/v1/event-ssr?slug=$1"
    },
    {
      "src": "^/events/?$",
      "dest": "/api/functions/v1/events-list-ssr"
    },

    {
      "src": "^/artists/([^/]+)/?$",
      "dest": "/api/functions/v1/artist-ssr?slug=$1"
    },

    {
      "src": "^/jaipur/([^/]+)/?$",
      "dest": "/api/functions/v1/locality-ssr?slug=$1"
    },

    {
      "src": "^/localities/([^/]+)/?$",
      "status": 308,
      "headers": { "Location": "/jaipur/$1" }
    },
    {
      "src": "^/localities/?$",
      "status": 308,
      "headers": { "Location": "/jaipur" }
    },

    {
      "src": "^/stories/([^/]+)/?$",
      "dest": "/api/functions/v1/story-ssr?slug=$1"
    },
    {
      "src": "^/stories/?$",
      "dest": "/api/functions/v1/stories-index-ssr"
    },

    {
      "src": "^/sitemap\\.xml$",
      "dest": "/api/functions/v1/sitemap-index"
    },
    {
      "src": "^/sitemap-events\\.xml$",
      "dest": "/api/functions/v1/sitemap-events-xml"
    },
    {
      "src": "^/sitemap-stories\\.xml$",
      "dest": "/api/functions/v1/sitemap-stories"
    },
    {
      "src": "^/sitemap-news\\.xml$",
      "dest": "/api/functions/v1/sitemap?type=news"
    },
    {
      "src": "^/sitemap-news-google\\.xml$",
      "dest": "/api/functions/v1/sitemap?type=news-sitemap"
    },
    {
      "src": "^/sitemap-artists\\.xml$",
      "dest": "/api/functions/v1/sitemap-artists"
    },

    { "src": "^/(.*)$", "dest": "/index.html" }
  ]
}
