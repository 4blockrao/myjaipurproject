    {
      "src": "^/sitemap-news\\.xml$",
      "dest": "https://rbenryjgtbrjvqvxbigq.supabase.co/functions/v1/sitemap?type=news"
    },
    {
      "src": "^/sitemap-news-google\\.xml$",
      "dest": "https://rbenryjgtbrjvqvxbigq.supabase.co/functions/v1/sitemap?type=news-sitemap"
    },
    {
      "src": "^/sitemap-artists\\.xml$",
      "dest": "https://rbenryjgtbrjvqvxbigq.supabase.co/functions/v1/sitemap-artists"
    },
    {
      "src": "^/localities/([^/]+)/?$",
      "status": 308,
      "headers": { "Location": "/jaipur/$1" }
    },
    {
      "src": "^/localities/?$",
      "status": 308,
      "headers": { "Location": "/jaipur" }
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^(.*)$",
      "dest": "/index.html"
    }
